<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Roadmap</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>
.fade-out {
    opacity: 0;
    transition: 0.4s ease;
}
</style>
</head>

<body class="bg-[#FCFCFC] overflow-x-hidden">

<!-- BACKGROUND -->
<div class="fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-52 -left-52 w-[700px] h-[700px] rounded-full bg-[#B9F6CA] opacity-70 blur-[180px]"></div>
    <div class="absolute -bottom-60 -right-60 w-[850px] h-[850px] rounded-full bg-[#8EE8FF] opacity-70 blur-[180px]"></div>
</div>

<!-- NAV -->
<div class="fixed left-6 top-1/2 -translate-y-1/2 z-50">
    <audio id="homeSound" src="image/dragon-studio-mouse-click-sound-376877.mp3"></audio>
    <button onclick="goHome()" class="hover:scale-110 transition">
        <img src="/image/icons8-curly-arrow-50.png" class="w-10 h-10">
    </button>
</div>

<div class="fixed right-6 top-1/2 -translate-y-1/2 z-50">
    <audio id="nextSound" src="image/dragon-studio-mouse-click-sound-376877.mp3"></audio>
    <button onclick="goNext()" class="hover:scale-110 transition">
        <img src="/image/icons8-curved-arrow-64.png" class="w-10 h-10">
    </button>
</div>

<!-- TITLE -->
<section id="page" class="py-20">

<div class="text-center mb-28">
    <h1 class="text-6xl font-black">My Roadmap</h1>
    <p class="mt-4 text-gray-500 text-lg">
        Education • Internships • Certifications • Career Path
    </p>
</div>

<!-- ROADMAP -->
<div class="relative max-w-6xl mx-auto">

<!-- CENTER LINE -->
<div class="absolute left-1/2 top-0 -translate-x-1/2 w-1 h-full bg-gray-300 rounded-full"></div>

<!-- 1 -->
<div class="flex justify-start mb-24">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">Diploma (Completed)</h2>
        <p class="text-gray-500 mt-2">Strong foundation in programming & computer science.</p>
    </div>
</div>

<!-- 2 -->
<div class="flex justify-end mb-24">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">NIELIT Foundation</h2>
        <p class="text-gray-500 mt-2">Computer fundamentals + certification preparation.</p>
    </div>
</div>

<!-- 3 -->
<div class="flex justify-start mb-24">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">AICTE Internship</h2>
        <p class="text-gray-500 mt-2">Real-world internship experience under AICTE programs.</p>
    </div>
</div>

<!-- 4 -->
<div class="flex justify-end mb-24">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">Android Security</h2>
        <p class="text-gray-500 mt-2">APK reverse engineering, security analysis, ethical hacking basics.</p>
    </div>
</div>

<!-- 5 -->
<div class="flex justify-start mb-24">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">Game Development</h2>
        <p class="text-gray-500 mt-2">Unity, Godot, animations, multiplayer systems.</p>
    </div>
</div>

<!-- 6 -->
<div class="flex justify-end mb-24">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">Web Development Internship</h2>
        <p class="text-gray-500 mt-2">Frontend + Backend real project experience.</p>
    </div>
</div>

<!-- 7 -->
<div class="flex justify-start mb-24">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">AI & Machine Learning</h2>
        <p class="text-gray-500 mt-2">Python, ML, Deep Learning, GenAI projects.</p>
    </div>
</div>

<!-- 8 -->
<div class="flex justify-end mb-24">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">B.Tech</h2>
        <p class="text-gray-500 mt-2">Engineering degree with strong portfolio building.</p>
    </div>
</div>

<!-- 9 -->
<div class="flex justify-start mb-24">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">Lenskart Placement Prep</h2>
        <p class="text-gray-500 mt-2">DSA, React, Node.js, interview preparation.</p>
    </div>
</div>

<!-- 10 -->
<div class="flex justify-end">
    <div class="w-[45%] bg-white p-8 rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">Honda / Final Career Goal</h2>
        <p class="text-gray-500 mt-2">Software Engineer in automotive or product-based company.</p>
    </div>
</div>

</div>

</section>

<script>

function goHome() {
    document.getElementById("homeSound").play();
    document.getElementById("page").classList.add("fade-out");

    setTimeout(() => window.location.href = "/", 400);
}

function goNext() {
    document.getElementById("nextSound").play();
    document.getElementById("page").classList.add("fade-out");

    setTimeout(() => window.location.href = "/projects", 400);
}

</script>

</body>
</html>